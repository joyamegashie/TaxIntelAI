
{
"$schema": "https://docs.renovatebot.com/renovate-schema.json",
"extends": [
"config:base",
":semanticCommits",
":semanticCommitTypeAll(chore)",
":dependencyDashboard",
":disableRateLimiting",
":timezone(Africa/Nairobi)",
"group:allNonMajor",
"schedule:weekly",
"helpers:pinGitHubActionDigests"
],

"enabledManagers": [
"npm",
"pip_requirements",
"poetry",
"dockerfile",
"github-actions",
"terraform",
"gradle",
"maven",
"nuget",
"gomod"
],

"dependencyDashboard": true,
"dependencyDashboardApproval": false,

"automerge": false,
"automergeType": "branch",
"major": {
"automerge": false
},
"minor": {
"automerge": true
},
"patch": {
"automerge": true
},

"rangeStrategy": "bump",
"rebaseWhen": "behind-base-branch",
"prCreation": "not-pending",
"branchConcurrentLimit": 10,
"prHourlyLimit": 5,

"packageRules": [
{
"matchManagers": ["github-actions"],
"groupName": "GitHub Actions dependencies",
"schedule": ["before 5am on monday"]
},
{
"matchManagers": ["dockerfile"],
"groupName": "Docker base images",
"schedule": ["before 5am on monday"]
},
{
"matchManagers": ["npm", "pip_requirements", "poetry"],
"groupName": "App dependencies",
"matchUpdateTypes": ["minor", "patch"],
"automerge": true,
"labels": ["dependencies", "automerge"]
},
{
"matchManagers": ["npm", "pip_requirements", "poetry"],
"groupName": "Major version upgrades",
"matchUpdateTypes": ["major"],
"labels": ["dependencies", "breaking-change"]
},
{
"matchDepTypes": ["devDependencies"],
"groupName": "Development dependencies",
"automerge": true
},
{
"matchPackagePatterns": ["^eslint", "^prettier", "^jest"],
"groupName": "Lint/Test tools",
"automerge": true
}
],

"labels": ["dependencies"],
"commitMessagePrefix": "chore(deps): ",
"commitBody": "Update dependencies automatically using Mend Renovate.",
"onboarding": false,
"suppressNotifications": ["prIgnoreNotification"],
"prHeader": "🤖 Automated Dependency Update",
"rebaseStalePrs": true,
"rollbackPrs": true,
"dependencyDashboardAutoclose": true
}
