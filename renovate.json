{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":semanticCommits",
    ":rebaseStalePrs",
    "group:allNonMajor",
    ":automergeDisabled",
    ":prHourlyLimit2"
  ],
  "enabledManagers": [
    "npm",
    "pip_requirements",
    "dockerfile",
    "github-actions",
    "terraform",
    "gradle",
    "composer",
    "maven",
    "helm-values",
    "kubernetes"
  ],
  "labels": ["dependencies", "renovate-bot"],
  "rangeStrategy": "bump",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "high-priority"]
  },
  "packageRules": [
    {
      "description": "Auto-approve and auto-merge safe (minor + patch) updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": true,
      "matchManagers": [
        "npm",
        "pip_requirements",
        "dockerfile",
        "github-actions",
        "terraform"
      ],
      "reviewers": [],
      "labels": ["automerge", "safe-update"],
      "prTitle": "chore(deps): auto-merge {{depName}} to {{newVersion}}"
    },
    {
      "description": "Mark and separate major updates as breaking changes",
      "matchUpdateTypes": ["major"],
      "labels": ["breaking-change"],
      "separateMajorMinor": true,
      "prPriority": 2,
      "prTitle": "feat(deps): upgrade {{depName}} to {{newVersion}} (major)"
    },
    {
      "description": "Group infrastructure and CI updates together",
      "matchManagers": ["terraform", "dockerfile", "kubernetes", "github-actions"],
      "groupName": "infrastructure-and-CI-dependencies",
      "groupSlug": "infra-ci"
    },
    {
      "description": "Detect and remove unused npm dependencies",
      "matchManagers": ["npm"],
      "postUpgradeTasks": {
        "commands": [
          "npx depcheck --json || true"
        ],
        "executionMode": "update"
      }
    }
  ],
  "rebaseWhen": "behind-base-branch",
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "osvVulnerabilityAlerts": true,
  "stabilityDays": 2,
  "prBodyNotes": [
    "✅ Auto-approved and merged safe dependency updates.",
    "🔒 Vulnerability scanning enabled for IaC and packages.",
    "⚙️ PR title standardized for audit and changelog tracking.",
    "🧹 Runs depcheck for unused dependencies cleanup."
  ],

  // 🗓️ Quiet operation settings
  "suppressNotifications": ["prEditedNotification"],
  "timezone": "Africa/Accra",
  "schedule": [
    "after 6am on monday",
    "before 6pm on friday",
    "every weekend: off"
  ],
  "dependencyDashboardHeader": "🗓️ Weekly Dependency Summary Report",
  "dependencyDashboardAutoclose": false,
  "masterIssue": true,
  "masterIssueTitle": "🧾 Weekly Dependency Update Report (All Projects)",
  "commitMessagePrefix": "chore(deps): ",
  "commitMessageAction": "update dependencies",
  "commitMessageTopic": "{{depName}}"
}
